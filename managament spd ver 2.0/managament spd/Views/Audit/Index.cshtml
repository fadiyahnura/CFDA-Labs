@model IEnumerable<ManagementSPD.Models.AuditLog>

@{
    ViewData["Title"] = "System Audit Logs";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-shield-alt me-2"></i>System Audit Logs</h1>
    </div>

    <div class="row mb-4">
        <div class="col-xl-6 col-lg-6">
            <div class="card shadow mb-4 h-100">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Activity Distribution</h6>
                </div>
                <div class="card-body">
                    <div class="chart-pie pt-4 pb-2" style="height: 300px;">
                        <canvas id="actionChart"></canvas>
                    </div>
                  
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-6">
            <div class="card shadow mb-4 h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Top 5 Most Active Users</h6>
                </div>
                <div class="card-body">
                    <div class="chart-bar" style="height: 300px;">
                        <canvas id="actorChart"></canvas>
                    </div>
                    <hr>
                    <small class="text-muted">Displays the 5 users with the most activity based on the current filter.</small>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-filter me-2"></i>Filter Logs</h6>
        </div>
        <div class="card-body bg-light">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Search</label>
                    <input type="text" name="search" class="form-control" value="@ViewBag.Search" placeholder="User or Activity...">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small">Action Type</label>
                    <select name="actionFilter" class="form-select">
                        <option value="">All Actions</option>
                        <option value="Login" selected="@(ViewBag.ActionFilter == "Login")">Login</option>
                        <option value="Create" selected="@(ViewBag.ActionFilter == "Create")">Create</option>
                        <option value="Update" selected="@(ViewBag.ActionFilter == "Update")">Update</option>
                        <option value="Delete" selected="@(ViewBag.ActionFilter == "Delete")">Delete</option>
                        <option value="Approve" selected="@(ViewBag.ActionFilter == "Approve")">Approve</option>
                        <option value="Reject" selected="@(ViewBag.ActionFilter == "Reject")">Reject</option>
                        <option value="Return" selected="@(ViewBag.ActionFilter == "Return")">Return</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small">Date Range</label>
                    <div class="input-group">
                        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate">
                        <span class="input-group-text">-</span>
                        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate">
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1"><i class="fas fa-search me-1"></i> Filter</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-undo"></i></a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th>Time</th>
                            <th>Actor (User)</th>
                            <th>Action</th>
                            <th>Target Table</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="small text-nowrap">@log.Timestamp.ToString("dd-MMM-yyyy HH:mm:ss")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-secondary text-white d-flex justify-content-center align-items-center me-2" style="width:30px; height:30px; font-size:0.8rem;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold d-block">@(log.User?.Username ?? "System")</span>
                                            <small class="text-muted" style="font-size:0.75rem;">@(log.User?.Role ?? "-")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (log.Action == "Login")
                                    {
                                        <span class="badge bg-primary">Login</span>
                                    }
                                    else if (log.Action == "Create")
                                    {

                                        <span class="badge bg-success">Create</span>
                                    }
                                    else if (log.Action == "Delete")
                                    {

                                        <span class="badge bg-danger">Delete</span>
                                    }
                                    else if (log.Action == "Approve")
                                    {

                                        <span class="badge bg-info text-dark">Approve</span>
                                    }
                                    else if (log.Action == "Reject")
                                    {

                                        <span class="badge bg-warning text-dark">Reject</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-secondary">@log.Action</span>
                                    }
                                </td>
                                <td class="small">
                                    <span class="d-block fw-bold text-dark">@log.TableName</span>
                                    <span class="text-muted" style="font-size:0.75rem;">ID: @log.RecordID</span>
                                </td>
                                <td class="small text-dark">@log.Details</td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No audit logs found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chart.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // CHART: Action Distribution 
            var ctxAction = document.getElementById("actionChart");
            if (ctxAction) {
                var actionColors = ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796'];

                new Chart(ctxAction, {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(ViewBag.ActionLabels ?? "[]"),
                        datasets: [{
                            data: @Html.Raw(ViewBag.ActionCounts ?? "[]"),
                            backgroundColor: actionColors,
                            hoverBackgroundColor: actionColors,
                            hoverBorderColor: "rgba(234, 236, 244, 1)",
                        }],
                    },
                    options: {
                        maintainAspectRatio: false,
                        tooltips: {
                            backgroundColor: "rgb(255,255,255)",
                            bodyFontColor: "#858796",
                            borderColor: '#dddfeb',
                            borderWidth: 1,
                            xPadding: 15,
                            yPadding: 15,
                            displayColors: false,
                            caretPadding: 10,
                        },
                        legend: { display: true, position: 'bottom' },
                        cutoutPercentage: 70,
                    },
                });
            }

            //  CHART: Top Users 
            var ctxActor = document.getElementById("actorChart");
            if (ctxActor) {
                new Chart(ctxActor, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(ViewBag.ActorLabels ?? "[]"),
                        datasets: [{
                            label: "Total Activities",
                            backgroundColor: "#4e73df",
                            hoverBackgroundColor: "#2e59d9",
                            borderColor: "#4e73df",
                            data: @Html.Raw(ViewBag.ActorCounts ?? "[]"),
                        }],
                    },
                    options: {
                        maintainAspectRatio: false,
                        layout: { padding: { left: 10, right: 25, top: 25, bottom: 0 } },
                        scales: {
                            xAxes: [{
                                gridLines: { display: false, drawBorder: false },
                                ticks: { maxTicksLimit: 6 },
                                maxBarThickness: 50,
                            }],
                            yAxes: [{
                                ticks: {
                                    min: 0,
                                    maxTicksLimit: 5,
                                    padding: 10,
                                    callback: function(value) { if (value % 1 === 0) {return value;} }
                                },
                                gridLines: {
                                    color: "rgb(234, 236, 244)",
                                    zeroLineColor: "rgb(234, 236, 244)",
                                    drawBorder: false,
                                    borderDash: [2],
                                    zeroLineBorderDash: [2]
                                }
                            }],
                        },
                        legend: { display: false },
                        tooltips: {
                            backgroundColor: "rgb(255,255,255)",
                            bodyFontColor: "#858796",
                            titleFontColor: '#6e707e',
                            titleFontSize: 14,
                            borderColor: '#dddfeb',
                            borderWidth: 1,
                            xPadding: 15,
                            yPadding: 15,
                            displayColors: false,
                            intersect: false,
                            mode: 'index',
                            caretPadding: 10,
                        }
                    }
                });
            }
        });
    </script>
}