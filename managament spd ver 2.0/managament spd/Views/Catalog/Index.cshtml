@model IEnumerable<ManagementSPD.Models.License>

@{
    ViewData["Title"] = "License Catalog";
    Layout = "_Layout";
    var trendingIds = ViewBag.TrendingIds as List<int> ?? new List<int>();
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-store text-primary me-2"></i>Software License Catalog</h1>
        <p class="text-muted mb-0">Browse, discover, and request available software licenses.</p>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            string iconClass = "fas fa-box";
            string iconColor = "#858796";
            string categoryName = item.Category?.ToLower() ?? "";

            if (categoryName.Contains("design") || categoryName.Contains("multimedia"))
            {
                iconClass = "fas fa-palette";
                iconColor = "#e74a3b";
            }
            else if (categoryName.Contains("office") || categoryName.Contains("document"))
            {
                iconClass = "fas fa-file-word";
                iconColor = "#4e73df";
            }
            else if (categoryName.Contains("developer") || categoryName.Contains("programming"))
            {
                iconClass = "fas fa-code";
                iconColor = "#1cc88a";
            }
            else if (categoryName.Contains("network") || categoryName.Contains("security"))
            {
                iconClass = "fas fa-network-wired";
                iconColor = "#f6c23e";
            }

            bool isTrending = trendingIds.Contains(item.LicenseID);

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card shadow-sm h-100 border-0 @(isTrending ? "border-primary shadow" : "")" style="border-radius: 15px; transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">

                    <div class="card-body text-center p-4 position-relative">

                        @if (isTrending)
                        {
                            <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-danger" style="font-size: 0.8rem; z-index: 10;">
                                <i class="fas fa-fire me-1"></i> Trending
                            </span>
                        }

                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 mt-2" style="width: 70px; height: 70px; background-color: @(iconColor)15; color: @iconColor; font-size: 30px;">
                            <i class="@iconClass"></i>
                        </div>

                        <h5 class="fw-bold text-dark mb-1">@item.LicenseName</h5>
                        <span class="badge bg-light text-dark border mb-3">@item.Category</span>

                        <div class="mb-3">
                            @if (item.AvailableQuantity > 0)
                            {
                                <span class="badge @(item.AvailableQuantity < 5 ? "bg-warning" : "bg-info") rounded-pill px-3 py-2">
                                    <i class="fas fa-cubes me-1"></i> Available: @item.AvailableQuantity
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2">
                                    <i class="fas fa-exclamation-circle me-1"></i> Unavailable
                                </span>
                            }
                        </div>

                        <p class="text-muted small">
                            @(string.IsNullOrEmpty(item.Description) ? "No description available for this software." : item.Description)
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0 pb-4 text-center">
                        @if (item.AvailableQuantity > 0)
                        {
                            <a href="/LoanTransaction/Create?licenseName=@item.LicenseName" class="btn btn-outline-primary rounded-pill px-4 fw-bold w-100">
                                <i class="fas fa-paper-plane me-1"></i> Request
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary rounded-pill px-4 fw-bold w-100" disabled>
                                <i class="fas fa-ban me-1"></i> Not Available
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-box-open fa-4x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">No licenses available in the catalog yet.</h5>
            </div>
        }
    </div>
</div>