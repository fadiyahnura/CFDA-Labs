@model ManagementSPD.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_LayoutRegister";
}

<div class="register-page-wrapper">

    <div class="register-branding">
        <img src="~/image/logo_baru.png" alt="Management SPD Logo">
    </div>

    <div class="register-form-container">
        <h2>Create an Account</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3 py-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0 small">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="Register" asp-controller="Account" method="post">

            <label asp-for="Username" class="form-label">Username</label>
            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
                <input asp-for="Username" class="form-control" placeholder="Enter your username" required />
            </div>

            <label asp-for="EmployeeNo" class="form-label">Employee No</label>
            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                <input asp-for="EmployeeNo" class="form-control" placeholder="Format: 11AA26" pattern="\d{2}[A-Za-z]{2}\d{2}" title="Format must be 2 Digits + 2 Letters + 2 Digits (Example: 11AA26)" style="text-transform:uppercase" required />
            </div>

            <label asp-for="ContractID" class="form-label">Contract ID (Optional)</label>
            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fas fa-file-contract"></i></span>
                <input asp-for="ContractID" class="form-control" placeholder="Enter your contract ID" />
            </div>

            <label asp-for="Email" class="form-label">Email <small class="text-muted"></small></label>
            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <input asp-for="Email" class="form-control" type="email" placeholder="example@gmail.com" />
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Enter password" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm password" required />
                    </div>
                </div>
            </div>

            <label asp-for="Role" class="form-label">Role </label>
            <div class="input-group mb-3" required>
                <span class="input-group-text"><i class="fas fa-user-tag"></i></span>
                <select asp-for="Role" class="form-select">
                    <option value="">-- Select role --</option>
                    <option value="Employee">Employee</option>
                    <option value="Staff">Staff</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">Register Account</button>

            <div class="text-center mt-4">
                <p>
                    Already have an account?
                    <a asp-action="Login" asp-controller="Account" class="text-decoration-none fw-bold">Login here</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {
            // 1. VALIDASI PANJANG PASSWORD REAL-TIME
            $('#Password').on('input', function () {
                var password = $(this).val();
                var warningText = $('#password-warning');

                if (warningText.length === 0) {
                    warningText = $('<small id="password-warning" class="text-danger d-block mt-1"></small>');
                    $(this).parent().after(warningText);
                }

                if (password.length > 0 && password.length < 6) {
                    warningText.text("Password must be at least 6 characters long.");
                    $(this).addClass("is-invalid");
                } else {
                    warningText.text("");
                    $(this).removeClass("is-invalid");
                    if(password.length >= 6) $(this).addClass("is-valid");
                }
            });

            // 2. CEK KONFIRMASI PASSWORD REAL-TIME
            $('#ConfirmPassword').on('input', function () {
                var password = $('#Password').val();
                var confirm = $(this).val();
                var warningText = $('#confirm-warning');

                if (warningText.length === 0) {
                    warningText = $('<small id="confirm-warning" class="text-danger d-block mt-1"></small>');
                    $(this).parent().after(warningText);
                }

                if (confirm !== password) {
                    warningText.text("Passwords do not match.");
                    $(this).addClass("is-invalid");
                } else {
                    warningText.text("");
                    $(this).removeClass("is-invalid");
                    if(confirm.length > 0) $(this).addClass("is-valid");
                }
            });
        });
    </script>
}