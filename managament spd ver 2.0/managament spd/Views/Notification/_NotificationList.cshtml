@model IEnumerable<ManagementSPD.Models.Notification>

<style>
    .notif-item {
        transition: background-color 0.2s;
        cursor: pointer;
        text-decoration: none; 
    }

        .notif-item:hover {
            background-color: #f8f9fa;
            text-decoration: none;
        }

    .notif-unread-bg {
        background-color: #eef2ff; 
        border-left: 4px solid #4e73df;
    }
</style>

<div class="list-group list-group-flush">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            string activeClass = !item.IsRead ? "notif-unread-bg" : "bg-white";
            string textWeight = !item.IsRead ? "fw-bold text-dark" : "text-secondary";
            string iconColor = !item.IsRead ? "text-primary" : "text-muted";
            <a asp-controller="Notification"
               asp-action="ReadAndRedirect"
               asp-route-id="@item.NotificationID"
               class="list-group-item list-group-item-action flex-column align-items-start p-3 mb-2 border rounded notif-item @activeClass">

                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fas fa-info-circle @iconColor fa-lg"></i>
                        </div>
                        <small class="text-muted">@item.CreatedAt.ToString("dd MMM yyyy, HH:mm")</small>
                    </div>

                    @if (!item.IsRead)
                    {
                        <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem;">NEW</span>
                    }
                </div>

                <p class="mb-1 ms-4 @textWeight" style="font-size: 0.9rem;">
                    @item.Message
                </p>
            </a>
        }
    }
    else
    {
        <div class="text-center p-5">
            <i class="fas fa-bell-slash fa-3x text-gray-300 mb-3"></i>
            <p class="text-muted">You have no notifications at the moment.</p>
        </div>
    }
</div>