@model ManagementSPD.Models.LoanTransaction

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="TransactionID" />
    <input type="hidden" asp-for="EmployeeID" />
    <input type="hidden" asp-for="LicenseID" />

    <div class="modal-body">

        <div class="mb-3">
            <label class="form-label fw-bold">Item Name</label>
            <input class="form-control" value="@Model.License?.LicenseName" readonly disabled />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Borrower</label>
            <input class="form-control" value="@Model.Employee?.Username (@Model.Employee?.EmployeeNo)" readonly disabled />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Qty" class="form-label fw-bold">Quantity</label>
                <input asp-for="Qty" class="form-control" type="number" min="1" required />
                <span asp-validation-for="Qty" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="DueDate" class="form-label fw-bold">Due Date</label>
                <input asp-for="DueDate" class="form-control" type="date" required />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Status" class="form-label fw-bold">Status (Force Update)</label>
            <select asp-for="Status" class="form-select">
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Returned">Returned</option>
                <option value="Rejected">Rejected</option>
            </select>
            <small class="text-muted">Only change status manually if necessary.</small>
        </div>

        <div class="mb-3">
            <label asp-for="Remarks" class="form-label fw-bold">Remarks</label>
            <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
        </div>
    </div>

    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning fw-bold">Save Changes</button>
    </div>
</form>




































































