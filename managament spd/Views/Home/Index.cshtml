@{
    ViewData["Title"] = "Welcome";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Management SPD - License Management System</title>
    <link rel="icon" type="image/png" href="~/image/logo_robot___7_-removebg-preview.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fc;
            overflow-x: hidden;
        }


        .landing-nav {
            position: absolute;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 25px 0;
            transition: all 0.3s;
        }

        .brand-logo {
            font-size: 1.6rem;
            font-weight: 800;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            letter-spacing: 1px;
        }

            .brand-logo i, .brand-logo img {
                filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
            }

        .hero-section {
            background: linear-gradient(135deg, rgba(30, 60, 114, 0.95) 0%, rgba(42, 82, 152, 0.90) 100%), url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: white;
            padding: 180px 0 140px 0;
            position: relative;
            border-bottom-left-radius: 80px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .hero-badge {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: #fff;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 2px;
            display: inline-block;
            margin-bottom: 25px;
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 25px;
            text-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .hero-subtitle {
            font-size: 1.25rem;
            font-weight: 300;
            opacity: 0.95;
            margin-bottom: 50px;
            max-width: 750px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.8;
        }


        .btn-glow {
            background: white;
            color: #2a5298;
            font-weight: 700;
            padding: 16px 45px;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.4s ease;
            box-shadow: 0 5px 20px rgba(255, 255, 255, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .btn-glow:hover {
                transform: translateY(-5px) scale(1.05);
                box-shadow: 0 10px 30px rgba(255, 255, 255, 0.5);
                color: #1e3c72;
            }

        .btn-outline-glow {
            background: transparent;
            border: 2px solid rgba(255,255,255,0.6);
            color: white;
            font-weight: 600;
            padding: 14px 40px;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            margin-left: 20px;
        }

            .btn-outline-glow:hover {
                background: rgba(255,255,255,0.1);
                border-color: white;
                color: white;
            }

        .features-container {
            margin-top: -80px;
            position: relative;
            z-index: 10;
            padding-bottom: 80px;
        }

        .feature-card {
            background: white;
            padding: 45px 35px;
            border-radius: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(0,0,0,0.02);
            height: 100%;
            text-align: center;
        }

            .feature-card:hover {
                transform: translateY(-15px);
                box-shadow: 0 25px 50px rgba(78, 115, 223, 0.2);
            }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #eef2ff 0%, #ffffff 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px auto;
            color: #4e73df;
            font-size: 32px;
            box-shadow: 0 10px 20px rgba(78, 115, 223, 0.1);
            transition: all 0.4s;
        }

        .feature-card:hover .icon-wrapper {
            background: #4e73df;
            color: white;
            transform: rotate(360deg);
        }

        .feature-title {
            font-weight: 700;
            margin-bottom: 15px;
            color: #2c3e50;
        }

        .feature-text {
            color: #6c757d;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        footer {
            background-color: white;
            padding: 60px 0 30px 0;
            border-top: 1px solid #edf2f9;
        }

        .footer-brand {
            font-weight: 800;
            color: #2c3e50;
            font-size: 1.5rem;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <nav class="landing-nav animate__animated animate__fadeInDown">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="#" class="brand-logo">
                <img src="~/image/logo_robot___7_-removebg-preview.png" alt="Management SPD Logo" style="height: 35px; width: auto;" class="me-2" />
                Management SPD
            </a>
            <div>
                <a href="/Account/Login" class="btn btn-outline-light rounded-pill px-4 fw-bold shadow-sm">
                    <i class="fas fa-sign-in-alt me-2"></i> Login
                </a>
            </div>
        </div>
    </nav>

    <section class="hero-section text-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="animate__animated animate__fadeInUp">
                        <span class="hero-badge">LICENSE MANAGEMENT SYSTEM </span>
                    </div>

                    <h1 class="hero-title animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                        Software License <br> Management
                    </h1>

                    <p class="hero-subtitle animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
                        A centralized platform to monitor, borrow, and manage software licenses efficiently.
                        Ensure compliance and optimize license usage with ease.
                    </p>

                    <div class="animate__animated animate__fadeInUp" style="animation-delay: 0.6s;">
                        <a href="/Account/Login" class="btn-glow">
                            Get Started <i class="fas fa-arrow-right"></i>
                        </a>
                        <a href="#features" class="btn-outline-glow">
                            Learn More
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="features-container">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card animate__animated animate__fadeInUp" style="animation-delay: 0.8s;">
                        <div class="icon-wrapper">
                            <i class="fas fa-paper-plane"></i>
                        </div>
                        <h4 class="feature-title">Digital License Request</h4>
                        <p class="feature-text">
                            Submit requests for software licenses easily. The system streamlines the application process directly to the admin for quick approval.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card animate__animated animate__fadeInUp" style="animation-delay: 1.0s;">
                        <div class="icon-wrapper">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <h4 class="feature-title">Easy Loan Process</h4>
                        <p class="feature-text">
                            Simplify the borrowing and returning of software keys. All transaction history is automatically recorded for accountability.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card animate__animated animate__fadeInUp" style="animation-delay: 1.2s;">
                        <div class="icon-wrapper">
                            <i class="fas fa-bell"></i>
                        </div>
                        <h4 class="feature-title">Expiration Alerts</h4>
                        <p class="feature-text">
                            Never miss a deadline. The system sends intelligent notifications for license expiration and return due dates.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container text-center">
            <div class="animate__animated animate__fadeIn" style="animation-delay: 1.5s;">
                <div class="mb-3">
                    <img src="~/image/logo_robot___7_-removebg-preview.png" alt="Management SPD Logo" style="height: 50px; width: auto;" />
                </div>
                <h5 class="footer-brand">Management SPD</h5>
                <p class="text-muted small mb-4">Internal System for Software License Management</p>

                <div class="border-top pt-4 w-50 mx-auto">
                    <p class="mb-1 small fw-bold text-dark">&copy; 2026 Management SPD. All Rights Reserved.</p>
                    <p class="mb-0 small text-muted">Developed for Final Project</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Smooth Scroll Effect
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>