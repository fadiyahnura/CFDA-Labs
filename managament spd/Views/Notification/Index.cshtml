@model IEnumerable<ManagementSPD.Models.Notification>

@{
    ViewData["Title"] = "All Notifications";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 text-gray-800"><i class="fas fa-bell text-primary me-2"></i>All Notifications</h2>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        string activeClass = !item.IsRead ? "bg-aliceblue border-left-primary" : "";
                        string textWeight = !item.IsRead ? "fw-bold text-dark" : "text-secondary";
                        string iconColor = !item.IsRead ? "text-primary" : "text-muted";

                        <a asp-action="ReadAndRedirect" asp-route-id="@item.NotificationID"
                           class="list-group-item list-group-item-action flex-column align-items-start p-3 @activeClass">

                            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light p-2 me-3">
                                        <i class="fas fa-info-circle @iconColor fa-lg"></i>
                                    </div>
                                    <h6 class="mb-0 @textWeight">System Notification</h6>
                                </div>
                                <small class="text-muted"><i class="far fa-clock me-1"></i> @item.CreatedAt.ToString("dd MMM yyyy, HH:mm")</small>
                            </div>

                            <p class="mb-1 ms-5 @textWeight">
                                @item.Message
                            </p>

                            @if (!item.IsRead)
                            {
                                <small class="ms-5 text-primary fw-bold">New</small>
                            }
                        </a>
                    }
                }
                else
                {
                    <div class="text-center p-5">
                        <i class="fas fa-bell-slash fa-3x text-gray-300 mb-3"></i>
                        <p class="text-muted">You have no notifications at the moment.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-aliceblue {
        background-color: #f8f9fc;
    }

    .border-left-primary {
        border-left: 4px solid #4e73df !important;
    }
</style>