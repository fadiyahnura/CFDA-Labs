@model ManagementSPD.Models.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-user-edit me-2"></i>Account Information</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-lg-5">
                        <h5 class="mb-3">User Details</h5>
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user fa-fw"></i></span>
                                <input asp-for="Username" class="form-control" readonly style="background-color: #e9ecef;" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="EmployeeNo" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-id-card fa-fw"></i></span>
                                <input asp-for="EmployeeNo" class="form-control" readonly style="background-color: #e9ecef;" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Role" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tag fa-fw"></i></span>
                                <input asp-for="Role" class="form-control" readonly style="background-color: #e9ecef;" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ContractID" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-file-contract fa-fw"></i></span>
                                <input asp-for="ContractID" class="form-control" readonly style="background-color: #e9ecef;" />
                            </div>
                        </div>
                    </div>

                    <div class="d-none d-lg-block col-lg-1">
                        <div class="vr h-100"></div>
                    </div>

                    <div class="col-lg-6">
                        <h5 class="mb-3">Edit Data</h5>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope fa-fw"></i></span>
                                <input asp-for="Email" class="form-control" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />
                        <h6><i class="fas fa-key me-2"></i>Edit Password</h6>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label"></label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label"></label>
                            <input asp-for="NewPassword" class="form-control" type="password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="mt-4" />
                <div class="d-flex justify-content-end">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary me-2">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>