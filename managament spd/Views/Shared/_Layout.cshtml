<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Management SPD</title>
    <link rel="icon" type="image/png" href="~/image/logo_robot___7_-removebg-preview.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />
    @RenderSection("Styles", required: false)


</head>
<body>
    <header class="app-header">
        <button id="sidebarCollapse" class="btn btn-link d-md-none">
            <i class="fas fa-bars"></i>
        </button>

        <div class="header-left-content">
            <div class="header-logo">
                <img src="~/image/logo_robot___7_-removebg-preview.png" alt="Management SPD Logo" class="logo-image-header" />
            </div>
            <h4 class="app-title">Management SPD</h4>
        </div>

        <div class="logout-section">
            @if (User.Identity.IsAuthenticated)
            {
                <span class="navbar-text me-2 user-name">
                    Halo, @User.Identity.Name!
                </span>
                <span class="navbar-text me-3 badge bg-primary user-role">
                    @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                </span>

                <a asp-controller="Profile" asp-action="Index" class="btn btn--primary me-2" title="Profile">
                    <i class="fas fa-user-circle"></i> Profile
                </a>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <div class="notification-section me-3">
                    @await Component.InvokeAsync("Notification")
                </div>
            }

            <a asp-action="Logout" asp-controller="Account" class="btn btn-outline-danger" title="Logout" id="logoutButton">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </header>

    <div class="app-wrapper" data-bs-backdrop="false">
        <nav id="sidebar" class="sidebar" data-bs-backdrop="false">
            <ul class="list-unstyled components" data-bs-backdrop="false">

                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-controller="Dashboard" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                </li>
                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" ? "active" : "")">
                    <a asp-controller="Catalog" asp-action="Index">
                        <i class="fas fa-store"></i> <span style="font-size: 15px;">Browse Licenses</span>
                    </a>
                </li>
                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "LoanTransaction" ? "active" : "")">
                    <a asp-controller="LoanTransaction" asp-action="Index"><i class="fas fa-file-invoice"></i> 
                        <span style="font-size: 15px;">Transactions Management</span>
                    </a>
                </li>

                @if (User.IsInRole("Staff") || User.IsInRole("MasterAdmin"))
                {
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ManagementUsers" ? "active" : "")">
                        <a asp-controller="ManagementUsers" asp-action="Index">
                            <i class="fas fa-users-cog"></i> Users Management
                        </a>
                    </li>
                }

                @if (User.IsInRole("MasterAdmin"))
                {
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Audit" ? "active" : "")">
                        <a asp-controller="Audit" asp-action="Index">
                            <i class="fas fa-shield-alt"></i> Audit Logs
                        </a>
                    </li>
                }

            </ul>
        </nav>

        <main role="main" class="content-wrapper">
            @RenderBody()
        </main>
    </div>

    <div class="modal fade" id="allNotifModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-bell me-2"></i>All Notifications</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0" id="allNotifContent">
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2025 - Management SPD
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function () {
            // Sidebar Toggle Logic
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
                $('.content-wrapper').toggleClass('sidebar-active');
                $('body').toggleClass('sidebar-open');
            });

            $('body').on('click', function (e) {
                if ($('body').hasClass('sidebar-open') && !$(e.target).closest('#sidebar, #sidebarCollapse').length) {
                    $('#sidebar').removeClass('active');
                    $('.content-wrapper').removeClass('sidebar-active');
                    $('body').removeClass('sidebar-open');
                }
            });

            // Logout Confirmation
            const logoutBtn = document.getElementById('logoutButton');
            if(logoutBtn){
                logoutBtn.addEventListener('click', function(event) {
                    var confirmed = confirm("Are you sure you want to exit?");
                    if (!confirmed) {
                        event.preventDefault();
                    }
                });
            }

            //  LOGIC AUTO-OPEN DETAIL FROM NOTIFICATION 
            const urlParams = new URLSearchParams(window.location.search);
            const detailsId = urlParams.get('openDetails');

            if (detailsId) {
                if ($('#detailsModal').length) {

                    var modal = new bootstrap.Modal(document.getElementById('detailsModal'));
                    $('#loadingDetails').show();
                    $('#detailsContent').hide();
                    modal.show();

                    $.get('/LoanTransaction/GetDetails/' + detailsId, function (data) {
                        $('#d-id').text(data.id);
                        $('#d-item').text(data.itemName);
                        $('#d-cat').text(data.category);
                        $('#d-empName').text(data.employeeName);
                        $('#d-empNo').text(data.employeeNo);
                        $('#d-qty').text(data.qty);
                        $('#d-req').text(data.requestDate);
                        $('#d-due').text(data.dueDate);
                        $('#d-ret').text(data.returnDate);
                        $('#d-rem').text(data.remarks);
                        $('#d-staff').text(data.processedBy);
                        $('#d-status').text(data.status);
                        $('#d-status').removeClass().addClass('badge p-2');
                        if(data.status === 'Approved') $('#d-status').addClass('bg-success');
                        else if(data.status === 'Pending') $('#d-status').addClass('bg-warning text-dark');
                        else if(data.status === 'Rejected') $('#d-status').addClass('bg-danger');
                        else $('#d-status').addClass('bg-primary');

                        $('#loadingDetails').hide();
                        $('#detailsContent').fadeIn();
                    }).fail(function() {
                        alert("Transaction detail not found or you don't have permission.");
                    });
                }
            }
        });

        //  GLOBAL FUNCTION: SHOW ALL NOTIFICATIONS 
        function showAllNotifications() {
            var modal = new bootstrap.Modal(document.getElementById('allNotifModal'));
            var contentDiv = document.getElementById('allNotifContent');
            contentDiv.innerHTML = '<div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Loading notifications...</p></div>';

            modal.show();

            fetch('/Notification/GetNotificationList')
                .then(response => response.text())
                .then(html => {
                    contentDiv.innerHTML = html;
                })
                .catch(error => {
                    contentDiv.innerHTML = '<div class="text-center p-4 text-danger"><i class="fas fa-exclamation-circle"></i> Failed to load notifications.</div>';
                });
        }
    </script>
</body>
</html>