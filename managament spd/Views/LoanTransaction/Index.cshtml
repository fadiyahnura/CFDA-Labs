@model IEnumerable<ManagementSPD.Models.LoanTransaction>

@{
    ViewData["Title"] = "Transactions Management";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 text-gray-800"> Transactions Management</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-2"></i>New Request
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-filter me-2"></i>Filter Data</h6>
        </div>
        <div class="card-body bg-light">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Search Licenses </label>
                    <input type="text" name="searchLicense" class="form-control" value="@ViewBag.SearchLicense" placeholder="Licenses Name...">
                </div>
                @if (User.IsInRole("Staff") || User.IsInRole("MasterAdmin"))
                {
                    <div class="col-md-2">
                        <label class="form-label fw-bold small">Select Employee</label>
                        <select name="employeeFilter" class="form-select" asp-items="@ViewBag.EmployeeList">
                            <option value="">All Employees</option>
                        </select>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label fw-bold small">Status / Remaining</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">All Status</option>
                        <option value="Active" selected="@(ViewBag.StatusFilter == "Active")">Active (Safe)</option>
                        <option value="Expired Soon" selected="@(ViewBag.StatusFilter == "Expired Soon")">Expired Soon (7 Days)</option>
                        <option value="Expired" selected="@(ViewBag.StatusFilter == "Expired")">Expired (Overdue)</option>
                        <option value="Returned" selected="@(ViewBag.StatusFilter == "Returned")">Returned</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Date Range</label>
                    <div class="input-group">
                        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate">
                        <span class="input-group-text">-</span>
                        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-undo"></i></a>
                    </div>
                </div>
            </form>
            <hr class="my-3">
            @if (User.IsInRole("Staff") || User.IsInRole("MasterAdmin"))
            {
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="ExportExcel" asp-route-searchLicense="@ViewBag.SearchLicense" asp-route-statusFilter="@ViewBag.StatusFilter" asp-route-employeeFilter="@ViewBag.EmployeeFilter" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="btn btn-success btn-sm shadow-sm"><i class="fas fa-file-excel me-1"></i> Export Excel</a>
                    <a asp-action="ExportPdf" asp-route-searchLicense="@ViewBag.SearchLicense" asp-route-statusFilter="@ViewBag.StatusFilter" asp-route-employeeFilter="@ViewBag.EmployeeFilter" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="btn btn-danger btn-sm shadow-sm"><i class="fas fa-file-pdf me-1"></i> Export PDF</a>
                </div>
            }
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-list me-2"></i>Transaction List</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" id="loanTable" width="100%">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Licenses Name</th>
                            <th>Employee</th>
                            <th>Req. Date</th>
                            <th>Due Date</th>
                            <th>Remaining</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            int remainingDays = (int)(item.DueDate - DateTime.Today).TotalDays;
                            string remainingClass = "bg-secondary";
                            string remainingText = "-";
                            if (item.Status == "Approved" || item.Status == "Pending")
                            {
                                if (remainingDays < 0) { remainingClass = "bg-danger"; remainingText = "Expired"; }
                                else if (remainingDays <= 7) { remainingClass = "bg-warning text-dark"; remainingText = $"{remainingDays} Days"; }
                                else { remainingClass = "bg-success"; remainingText = $"{remainingDays} Days"; }
                            }

                            <tr>
                                <td class="fw-bold text-primary">@(item.License != null ? item.License.LicenseName : "Unknown")</td>
                                <td>@(item.Employee != null ? item.Employee.EmployeeNo : "-")</td>
                                <td>@item.RequestDate.ToString("dd-MMM-yyyy")</td>
                                <td>@item.DueDate.ToString("dd-MMM-yyyy")</td>
                                <td class="text-center">
                                    @if (item.Status == "Returned" || item.Status == "Rejected")
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                    else
                                    {

                                        <span class="badge @remainingClass shadow-sm">@remainingText</span>
                                    }
                                </td>
                                <td class="text-center">@item.Qty</td>
                                <td class="text-center">
                                    @{
                                        string badgeClass = item.Status switch { "Approved" => "bg-success", "Pending" => "bg-warning text-dark", "Rejected" => "bg-danger", "Returned" => "bg-primary", _ => "bg-secondary" };
                                        string iconStatus = item.Status switch { "Approved" => "fas fa-check", "Pending" => "fas fa-clock", "Rejected" => "fas fa-times", "Returned" => "fas fa-undo", _ => "fas fa-question" };
                                    }
                                    <span class="badge @badgeClass shadow-sm"><i class="@iconStatus me-1"></i> @item.Status</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <button type="button" class="btn btn-sm btn-info btn-details text-white shadow-sm" data-id="@item.TransactionID" title="View Details"><i class="fas fa-eye"></i></button>

                                        @if (User.IsInRole("Staff") || User.IsInRole("MasterAdmin"))
                                        {
                                            <button type="button" class="btn btn-sm btn-warning btn-edit text-dark shadow-sm" data-id="@item.TransactionID" title="Edit Transaction"><i class="fas fa-edit"></i></button>

                                            @if (item.Status == "Pending")
                                            {
                                                <button type="button" class="btn btn-sm btn-success btn-action shadow-sm" data-id="@item.TransactionID" data-action="Approve" title="Approve"><i class="fas fa-check"></i></button>
                                                <button type="button" class="btn btn-sm btn-warning btn-action shadow-sm text-white" data-id="@item.TransactionID" data-action="Reject" title="Reject"><i class="fas fa-times"></i></button>
                                            }
                                            <button type="button" class="btn btn-sm btn-danger btn-delete shadow-sm" data-id="@item.TransactionID" title="Delete Transaction"><i class="fas fa-trash-alt"></i></button>
                                        }

                                        @if (User.IsInRole("Employee") && item.Status == "Approved")
                                        {
                                            <button type="button" class="btn btn-sm btn-primary btn-return shadow-sm" data-id="@item.TransactionID" data-name="@(item.License?.LicenseName)" title="Return Item"><i class="fas fa-undo-alt"></i></button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailsModal" tabindex="-1" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-info-circle me-2"></i>Transaction Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center" id="loadingDetails">
                    <div class="spinner-border text-info" role="status"></div>
                    <p class="mt-2 text-muted">Fetching data...</p>
                </div>

                <div id="detailsContent" style="display:none;">
                    <div class="row mb-3">
                        <div class="col-md-6 border-end">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3"><i class="fas fa-box-open me-1"></i> Item Information</h6>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="fas fa-hashtag text-info fa-fw me-2"></i> <strong>ID:</strong> <span id="d-id"></span></li>
                                <li class="mb-2"><i class="fas fa-cube text-info fa-fw me-2"></i> <strong>Item:</strong> <span id="d-item" class="fw-bold text-dark"></span></li>
                                <li class="mb-2"><i class="fas fa-tag text-info fa-fw me-2"></i> <strong>Category:</strong> <span id="d-cat"></span></li>
                                <li class="mb-2"><i class="fas fa-layer-group text-info fa-fw me-2"></i> <strong>Qty:</strong> <span id="d-qty"></span></li>
                            </ul>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3"><i class="fas fa-user me-1"></i> User Information</h6>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="fas fa-user-circle text-success fa-fw me-2"></i> <strong>Name:</strong> <span id="d-empName"></span></li>
                                <li class="mb-2"><i class="fas fa-id-card text-success fa-fw me-2"></i> <strong>No:</strong> <span id="d-empNo" class="badge bg-light text-dark border"></span></li>
                            </ul>
                        </div>
                    </div>

                    <hr class="my-3">

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3"><i class="fas fa-calendar-alt me-1"></i> Timeline</h6>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="far fa-calendar-plus text-warning fa-fw me-2"></i> <strong>Request:</strong> <span id="d-req"></span></li>
                                <li class="mb-2"><i class="far fa-calendar-times text-danger fa-fw me-2"></i> <strong>Due Date:</strong> <span id="d-due" class="fw-bold"></span></li>
                                <li class="mb-2"><i class="fas fa-undo-alt text-primary fa-fw me-2"></i> <strong>Returned:</strong> <span id="d-ret"></span></li>
                            </ul>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3"><i class="fas fa-info-circle me-1"></i> Status</h6>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="fas fa-flag text-primary fa-fw me-2"></i> <strong>Status:</strong> <span id="d-status"></span></li>
                                <li class="mb-2"><i class="fas fa-user-shield text-secondary fa-fw me-2"></i> <strong>By:</strong> <span id="d-staff"></span></li>
                            </ul>
                        </div>
                    </div>

                    <div class="alert alert-light border mt-3 d-flex align-items-start">
                        <i class="fas fa-comment-alt text-muted me-3 mt-1"></i>
                        <div>
                            <strong class="d-block text-muted small text-uppercase">Remarks</strong>
                            <span id="d-rem" class="fst-italic"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title text-dark"><i class="fas fa-edit me-2"></i>Edit Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div id="editModalContent">
                <div class="modal-body text-center p-4">
                    <div class="spinner-border text-warning" role="status"></div><p class="mt-2">Loading...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="actionModal" tabindex="-1" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="ProcessRequest" method="post">
                <div class="modal-header text-white"><h5 class="modal-title">Confirm Action</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="modalTransId" />
                    <input type="hidden" name="actionType" id="modalActionType" />
                    <p class="text-center">Are you sure you want to <strong id="actionText"></strong> this request?</p>
                    <div class="form-group"><label>Remarks:</label><textarea name="remarks" class="form-control" rows="2"></textarea></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Confirm</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="returnModal" tabindex="-1" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="ReturnItem" method="post">
                <div class="modal-header bg-primary text-white"><h5 class="modal-title">Return Item</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body text-center">
                    <input type="hidden" name="id" id="returnTransId" />
                    <p>Return <strong id="returnItemName"></strong>?</p>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Yes, Return It</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="Delete" method="post">
                <div class="modal-header bg-danger text-white"><h5 class="modal-title">Delete Transaction</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body text-center p-4">
                    <input type="hidden" name="id" id="deleteTransId" />
                    <p>Delete transaction ID <strong id="deleteIdDisplay"></strong>?</p>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-danger">Delete</button></div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            const urlParams = new URLSearchParams(window.location.search);
            const detailsId = urlParams.get('openDetails');

            if (detailsId) {
                showDetails(detailsId);
            }

            $(document).on('click', '.btn-details', function () {
                var id = $(this).data('id');
                showDetails(id);
            });

            function showDetails(id) {
                var modal = $('#detailsModal');
                $('#loadingDetails').show();
                $('#detailsContent').hide();

                $("#d-id").text("-"); $("#d-item").text("-");

                var myModal = new bootstrap.Modal(document.getElementById('detailsModal'));
                myModal.show();

                $.get('/LoanTransaction/GetDetails/' + id, function (data) {
                    $('#d-id').text(data.id); $('#d-item').text(data.itemName); $('#d-cat').text(data.category);
                    $('#d-empName').text(data.employeeName); $('#d-empNo').text(data.employeeNo); $('#d-qty').text(data.qty);
                    $('#d-req').text(data.requestDate); $('#d-due').text(data.dueDate); $('#d-ret').text(data.returnDate);
                    $('#d-rem').text(data.remarks); $('#d-staff').text(data.processedBy);

                    $('#d-status').text(data.status).removeClass().addClass('badge p-2');
                    if(data.status === 'Approved') $('#d-status').addClass('bg-success');
                    else if(data.status === 'Pending') $('#d-status').addClass('bg-warning text-dark');
                    else if(data.status === 'Rejected') $('#d-status').addClass('bg-danger');
                    else $('#d-status').addClass('bg-primary');

                    $('#loadingDetails').hide(); $('#detailsContent').fadeIn();
                }).fail(function() {
                    alert("Failed to load details.");
                });
            }

            $(document).on('click', '.btn-edit', function () {
                var id = $(this).data('id');
                var url = '/LoanTransaction/Edit/' + id;

                $('#editModalContent').html('<div class="modal-body text-center p-4"><div class="spinner-border text-warning"></div><p>Loading...</p></div>');

                var editModal = new bootstrap.Modal(document.getElementById('editModal'));
                editModal.show();

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (data) {
                        $('#editModalContent').html(data);
                    },
                    error: function (xhr) {
                        $('#editModalContent').html('<div class="alert alert-danger">Error: ' + xhr.status + ' (' + xhr.statusText + ')</div>');
                    }
                });
            });

            $(document).on('click', '.btn-action', function () {
                var id = $(this).data('id');
                var action = $(this).data('action');
                $('#modalTransId').val(id); $('#modalActionType').val(action); $('#actionText').text(action);
                var header = $('#actionModal .modal-header');
                header.removeClass('bg-success bg-warning');
                if(action === 'Approve') header.addClass('bg-success'); else header.addClass('bg-warning text-dark');
                var actionModal = new bootstrap.Modal(document.getElementById('actionModal'));
                actionModal.show();
            });

            $(document).on('click', '.btn-return', function () {
                var id = $(this).data('id');
                var name = $(this).data('name');
                $('#returnTransId').val(id); $('#returnItemName').text(name);
                var returnModal = new bootstrap.Modal(document.getElementById('returnModal'));
                returnModal.show();
            });

            $(document).on('click', '.btn-delete', function () {
                var id = $(this).data('id');
                $('#deleteTransId').val(id); $('#deleteIdDisplay').text(id);
                var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
                deleteModal.show();
            });
        });
    </script>
}