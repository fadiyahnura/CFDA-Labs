@model ManagementSPD.Models.LoanTransaction

@{
    ViewData["Title"] = "Request New Loan";
    Layout = "_Layout";

    // Ambil stok dari ViewBag (jika ada), jika tidak ada set ke '-'
    var stockToDisplay = ViewBag.AvailableStock != null ? ViewBag.AvailableStock.ToString() : "-";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-file-signature me-2"></i>New Loan Request</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Item Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-primary"><i class="fas fa-box-open"></i></span>

                                @{
                                    // Menangkap nama item dari URL (jika ada)
                                    var defaultItemName = Context.Request.Query["licenseName"].ToString();
                                    var isReadOnly = !string.IsNullOrEmpty(defaultItemName) ? "readonly" : "";
                                }

                                <input type="text" name="LicenseName" class="form-control"
                                       value="@defaultItemName" @isReadOnly
                                       placeholder="Type the item name (e.g., Canva, Adobe...)" required />
                            </div>

                            @if (!string.IsNullOrEmpty(Context.Request.Query["licenseName"]))
                            {
                                <small class="text-success fst-italic"><i class="fas fa-check-circle me-1"></i> Item selected from catalog.</small>
                            }
                            else
                            {
                                <small class="text-muted fst-italic">Ensure the item name is correct.</small>
                            }
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Qty" class="form-label fw-bold text-secondary">Quantity</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-primary"><i class="fas fa-sort-numeric-up"></i></span>

                                    <input asp-for="Qty" id="inputQty" class="form-control" type="number" min="1" value="1" required />

                                    <span class="input-group-text bg-light text-secondary">
                                        / &nbsp;<span id="stockDisplay" class="fw-bold text-dark">@stockToDisplay</span>&nbsp; stock
                                    </span>   @*add validation stock in column quantity form request *@
                                </div>
                                <span asp-validation-for="Qty" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="RequestDate" class="form-label fw-bold text-secondary">Start Date</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-primary"><i class="fas fa-calendar-plus"></i></span>
                                    <input asp-for="RequestDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                </div>
                                <span asp-validation-for="RequestDate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="DueDate" class="form-label fw-bold text-secondary">Return Date Plan</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-primary"><i class="fas fa-calendar-check"></i></span>
                                    <input asp-for="DueDate" class="form-control" type="date" required />
                                </div>
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Remarks" class="form-label fw-bold text-secondary">Remarks / Purpose</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-primary"><i class="fas fa-pen"></i></span>
                                <textarea asp-for="Remarks" class="form-control" rows="3" placeholder="E.g., Used for training session for new employees..."></textarea>
                            </div>
                            <span asp-validation-for="Remarks" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary shadow-sm">
                                <i class="fas fa-arrow-left me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary shadow-sm">
                                <i class="fas fa-paper-plane me-1"></i> Submit Request
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script untuk mengunci input angka sesuai dengan batas stok -->
@section Scripts {
    <script>
        $(document).ready(function() {
            // Ambil angka dari variabel C# ViewBag
            var availableStock = '@ViewBag.AvailableStock';

            // Jika ada angkanya (bukan kosong atau null)
            if (availableStock && availableStock !== '') {
                // Set batas maksimal panah atas di input Qty
                $('#inputQty').attr('max', availableStock);

                // Tambahan: jika user iseng ketik angka manual yang melebihi stok, otomatis turunkan
                $('#inputQty').on('input', function() {
                    var val = parseInt($(this).val());
                    var max = parseInt(availableStock);

                    if (val > max) {
                        $(this).val(max);
                    }
                });
            }
        });
    </script>
}